# =============================================================================
# HyperGuest B2B Channel Manager — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# HyperGuest API Authentication Tokens
# -----------------------------------------------------------------------------
# PRIMARY token — used for ALL HyperGuest API calls.
# Set this to your Bearer token from the Postman collection / HyperGuest portal.
NEXT_PUBLIC_HG_API_TOKEN=9d49c17f0b3a4c9d9693df041690eccc

# Legacy per-endpoint tokens (only needed if your account uses different
# tokens for different services; leave blank to inherit from HG_API_TOKEN).
NEXT_PUBLIC_HG_STATIC_TOKEN=9d49c17f0b3a4c9d9693df041690eccc

# Operations API token — used for ARI subscriptions (create / update / delete).
NEXT_PUBLIC_HG_OPERATIONS_TOKEN=fc35030b784648129cf3534a8d6fd0b8

# Callback verification token — included in every incoming ARI push from HyperGuest.
# Validate this header on your /api/callback endpoint to reject spoofed requests.
NEXT_PUBLIC_HG_CALLBACK_TOKEN=f99a7t2vlcr0swoNoC1qapac6ozoQ3tr


# -----------------------------------------------------------------------------
# HyperGuest Base URLs
# -----------------------------------------------------------------------------
# Static API — property metadata, facilities, room types, rate plans.
NEXT_PUBLIC_HG_STATIC_URL=https://hg-static.hyperguest.com

# Search API — live availability and rate search (ARI queries).
NEXT_PUBLIC_HG_SEARCH_URL=https://search-api.hyperguest.io

# PDM (Property Data Management) API — subscription management endpoints.
NEXT_PUBLIC_HG_PDM_URL=https://pdm.hyperguest.io

# Booking API — reservation commit, cancel, and amendment (OTA_HotelResNotif).
NEXT_PUBLIC_HG_BOOK_URL=https://book-api.hyperguest.com


# -----------------------------------------------------------------------------
# Eglobe / Channel Manager Callback & Subscription Settings
# -----------------------------------------------------------------------------
# The public HTTPS URL HyperGuest will POST ARI updates to.
# Must be reachable from the internet; use ngrok for local development.
NEXT_PUBLIC_EGLOBE_CALLBACK_URL=https://www.eglobe-solutions.com/webapichannelmanager/hyperguestb2bsubscription/callback/ariupdates

# Email address registered as the subscription owner on HyperGuest.
NEXT_PUBLIC_SUBSCRIPTION_EMAIL=it@eglobe-solutions.com


# -----------------------------------------------------------------------------
# MSSQL Database
# -----------------------------------------------------------------------------
# Hostname or IP of the SQL Server instance.
# For Docker Compose use the service name: db
DB_SERVER=localhost

# SQL Server port (default: 1433).
DB_PORT=1433

# Database name created by db/schema.sql.
DB_NAME=HyperGuestB2B

# SQL Server login (sa or a dedicated application user).
DB_USER=sa

# Password for the above user. Must meet SQL Server complexity requirements.
DB_PASSWORD=YourStrongPassword123!

# Set to true to encrypt the SQL Server connection (recommended in production).
DB_ENCRYPT=false

# Set to true only if your SQL Server uses a self-signed TLS certificate (dev/Docker).
DB_TRUST_SERVER_CERTIFICATE=true


# -----------------------------------------------------------------------------
# Next.js / NextAuth
# -----------------------------------------------------------------------------
# Secret used to sign NextAuth session tokens. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Full public URL of the Next.js app (no trailing slash).
NEXTAUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Node.js environment: development | production | test
NODE_ENV=development

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Enable verbose API logging to hg_api_logs table (true/false).
ENABLE_API_LOGGING=true

# Maximum number of properties to sync per Static API batch request.
SYNC_BATCH_SIZE=50
