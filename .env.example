# =============================================================================
# HyperGuest B2B Channel Manager — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# HyperGuest API Authentication Tokens
# -----------------------------------------------------------------------------
# PRIMARY token — used for ALL HyperGuest API calls.
NEXT_PUBLIC_HG_API_TOKEN=your-hg-api-token-here

# Static API token (leave blank to inherit from HG_API_TOKEN).
NEXT_PUBLIC_HG_STATIC_TOKEN=your-hg-static-token-here

# Operations API token — used for ARI subscriptions (create / update / delete).
NEXT_PUBLIC_HG_OPERATIONS_TOKEN=your-hg-operations-token-here

# Callback verification token — included in every incoming ARI push from HyperGuest.
NEXT_PUBLIC_HG_CALLBACK_TOKEN=your-hg-callback-token-here


# -----------------------------------------------------------------------------
# HyperGuest Base URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HG_STATIC_URL=https://hg-static.hyperguest.com
NEXT_PUBLIC_HG_SEARCH_URL=https://search-api.hyperguest.io
NEXT_PUBLIC_HG_PDM_URL=https://pdm.hyperguest.io
NEXT_PUBLIC_HG_BOOK_URL=https://book-api.hyperguest.com


# -----------------------------------------------------------------------------
# Eglobe / Channel Manager Callback & Subscription Settings
# -----------------------------------------------------------------------------
# The public HTTPS URL HyperGuest will POST ARI updates to.
NEXT_PUBLIC_EGLOBE_CALLBACK_URL=https://your-domain.com/api/callback/ariupdates

# Email address registered as the subscription owner on HyperGuest.
NEXT_PUBLIC_SUBSCRIPTION_EMAIL=your-email@example.com


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hyperguest_b2b
DB_USER=root
DB_PASSWORD=your-db-password-here


# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
ENABLE_API_LOGGING=true
SYNC_BATCH_SIZE=50
